# База данных (Supabase — для Vercel используйте порт 6543)
# Добавьте в конец: ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@host.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Секрет для JWT-сессий (сгенерируйте случайную строку 32+ символов)
JWT_SECRET="your-super-secret-jwt-key-change-me-in-production"

# URL сайта (обязательно https:// для ЮKassa в продакшене)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# === ЮKassa (ЮMoney) — заполните после модерации ===
# Получите в личном кабинете: https://yookassa.ru/my/shop-settings
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# Режим: test | live (test для проверки, live для реальных платежей)
YOOKASSA_MODE="test"

# Реквизиты для юридических страниц (требование ЮKassa)
COMPANY_NAME="ИП Иванов Иван Иванович"
COMPANY_INN="000000000000"
COMPANY_OGRN="0000000000000"
COMPANY_ADDRESS="г. Москва, ул. Примерная, д. 1"
COMPANY_EMAIL="info@flora-market.ru"
COMPANY_PHONE="+7 (999) 123-45-67"
